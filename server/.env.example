# ─────────────────────────────────────────────────────────────────────────────
# NANDI — environment variables  (copy to `.env`, fill in secrets)
#
# These names are the canonical contract from SoW §12.3. Every member MUST use
# these EXACT names. The block below the divider holds Member 1 additions that
# the rest of the team can ignore unless touching embeddings.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (pgvector included) ──────────────────────────────────────────
# asyncpg URL for the running app. Alembic derives a sync URL from this.
DATABASE_URL=postgresql+asyncpg://nandi:password@localhost:5432/nandi

# ── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SMS ─────────────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=NANDIK
GUPSHUP_API_KEY=

# ── IVR ─────────────────────────────────────────────────────────────────────
EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_VIRTUAL_NUMBER=

# ── Storage ─────────────────────────────────────────────────────────────────
AWS_S3_BUCKET=nandi-media
AWS_REGION=ap-south-1

# ── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
FACE_MODEL=buffalo_l

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRY_HOURS=8
INTERNAL_KEY=dev-internal-key-change-me

# ── OTP ─────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=14400   # 4 hours

# ═════════════════════════════════════════════════════════════════════════════
# Member 1 additions (matching / embedding internals). Safe defaults provided —
# you only need to touch these if you run the real ML models.
# ═════════════════════════════════════════════════════════════════════════════

# Face embedding dimension. InsightFace buffalo_l (ArcFace) outputs 512-dim.
FACE_EMBEDDING_DIM=512

# 1 = use the deterministic stub embedder (no model download, CPU-only, fast).
# 0 = load the real sentence-transformers / InsightFace models.
# Defaults to 1 so the team can build without GPUs. Flip to 0 for the demo box.
EMBEDDING_FALLBACK=1

# torch device for the real models: "cpu" | "cuda" | "mps"
EMBEDDING_DEVICE=cpu

# Matching knobs
MATCH_AGE_WINDOW=15          # ± years around the found person's approximate age
MATCH_CANDIDATE_LIMIT=10     # top-N pulled from pgvector before re-ranking
MATCH_RETURN_LIMIT=3         # candidates shown to the booth operator
MATCH_MIN_CONFIDENCE=0.60    # below this a candidate is NOT surfaced (SoW §6.3)
PGVECTOR_EF_SEARCH=64        # HNSW ef_search; raise for recall, lower for latency

# Materialized view refresh cadence (seconds) for scripts/refresh_views.py loop
MATVIEW_REFRESH_SECONDS=300
