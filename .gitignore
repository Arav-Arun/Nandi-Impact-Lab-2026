# Project-wide ignores

# Environment / secrets / config
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Python
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.eggs/
**/build/
**/dist/
**/.cache/
**/models/
**/*.onnx
**/.pytest_cache/
**/.coverage
**/htmlcov/
**/.mypy_cache/
**/.ruff_cache/
**/*.sqlite3
**/*.db
**/.venv/
**/venv/
**/env/

# Node
**/node_modules/
**/dist/

# User-uploaded media (keep the dir, ignore its contents)
server/uploads/*
!server/uploads/.gitkeep

# Editors / OS / Misc
.DS_Store
**/.DS_Store
.idea/
.vscode/
**/.idea/
**/.vscode/
*.log
**/*.log

# Claude Code local config
.claude/

# Markdown - keep only the top-level README
**/*.md
!/README.md
